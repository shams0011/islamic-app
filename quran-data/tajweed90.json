{"verses":{"1":"ل<i class=tj-madd>َآ</i> أُ<i class=tj-qalqalah>قْ</i>سِمُ بِهَ<i class=tj-madd>ـٰ</i>ذَا <i class=tj-silent>ٱ</i>لْبَلَ<i class=tj-qalqalah>د</i>ِ","2":"وَأَ<i class=tj-ikhfa>نت</i>َ حِل<i class=tj-ikhfa>ُّۢ ب</i>ِهَ<i class=tj-madd>ـٰ</i>ذَا <i class=tj-silent>ٱ</i>لْبَلَ<i class=tj-qalqalah>د</i>ِ","3":"وَوَالِ<i class=tj-ghunnah>دٍ و</i>َمَا وَلَ<i class=tj-qalqalah>د</i>َ","4":"لَقَ<i class=tj-qalqalah>دْ</i> خَلَ<i class=tj-qalqalah>قْ</i>نَا <i class=tj-silent>ٱ</i>لْإِ<i class=tj-ikhfa>نس</i>َ<i class=tj-madd>ـٰ</i>نَ فِى كَبَ<i class=tj-qalqalah>د</i>ٍ","5":"أَيَحْسَبُ أ<i class=tj-silent>َن ل</i>ّ<i class=tj-ghunnah>َن ي</i>َ<i class=tj-qalqalah>قْ</i>دِرَ عَلَيْهِ أَحَ<i class=tj-qalqalah>د</i>ٌ","6":"يَقُولُ أَهْلَكْتُ مَال<i class=tj-silent>اً ل</i>ُّبَدًا","7":"أَيَحْسَبُ أ<i class=tj-silent>َن ل</i>َّمْ يَرَهُ<i class=tj-madd>ۥٓ</i> أَحَ<i class=tj-qalqalah>د</i>ٌ","8":"أَلَمْ نَ<i class=tj-qalqalah>جْ</i>عَل لَّهُ<i class=tj-madd>ۥ</i> عَيْنَ<i class=tj-madd>يْ</i>نِ","9":"وَلِسَا<i class=tj-ghunnah>نًا و</i>َشَفَتَ<i class=tj-madd>يْ</i>نِ","10":"وَهَدَيْنَ<i class=tj-madd>ـٰ</i>هُ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i><i class=tj-ghunnah>نّ</i>َ<i class=tj-qalqalah>جْ</i>دَ<i class=tj-madd>يْ</i>نِ","11":"فَلَا <i class=tj-silent>ٱ</i><i class=tj-qalqalah>قْ</i>تَحَمَ <i class=tj-silent>ٱ</i>لْعَقَبَةَ","12":"وَم<i class=tj-madd>َآ</i> أَ<i class=tj-qalqalah>دْ</i>رَ<i class=tj-madd>ٮٰ</i>كَ مَا <i class=tj-silent>ٱ</i>لْعَقَبَةُ","13":"فَكُّ رَقَبَةٍ","14":"أَوْ إِ<i class=tj-qalqalah>طْ</i>عَ<i class=tj-madd>ـٰ</i><i class=tj-ikhfa>مٌ ف</i>ِى يَوْ<i class=tj-ikhfa>مٍ ذ</i>ِى مَسْغَبَةٍ","15":"يَتِي<i class=tj-ikhfa>مًا ذ</i>َا مَ<i class=tj-qalqalah>قْ</i>رَبَةٍ","16":"أَوْ مِسْكِي<i class=tj-ikhfa>نًا ذ</i>َا مَتْرَبَةٍ","17":"ثُ<i class=tj-ghunnah>مّ</i>َ كَانَ مِنَ <i class=tj-silent>ٱ</i>لَّذِينَ ءَامَنُو<i class=tj-silent>اْ</i> وَتَوَاصَوْ<i class=tj-silent>اْ</i> بِ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>صَّ<i class=tj-qalqalah>بْ</i>رِ وَتَوَاصَوْ<i class=tj-silent>اْ</i> بِ<i class=tj-silent>ٱ</i>لْمَرْحَمَةِ","18":"أُ<i class=tj-silent>وْ</i>لَ<i class=tj-madd>ـٰٓ</i>ئِكَ أَصْحَ<i class=tj-madd>ـٰ</i>بُ <i class=tj-silent>ٱ</i>لْمَيْمَنَةِ","19":"وَ<i class=tj-silent>ٱ</i>لَّذِينَ كَفَرُو<i class=tj-silent>اْ</i> بِـَٔـايَ<i class=tj-madd>ـٰ</i>تِنَا هُمْ أَصْحَ<i class=tj-madd>ـٰ</i>بُ <i class=tj-silent>ٱ</i>لْمَشْــَٔمَةِ","20":"عَلَيْهِمْ نَا<i class=tj-ghunnah>رٌ م</i>ُّؤْصَدَةُۢ"}}