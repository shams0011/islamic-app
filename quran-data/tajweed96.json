{"verses":{"1":"ٱ<i class=tj-qalqalah>قْ</i>رَأْ بِ<i class=tj-silent>ٱ</i>سْمِ رَبِّكَ <i class=tj-silent>ٱ</i>لَّذِى خَلَ<i class=tj-qalqalah>ق</i>َ","2":"خَلَقَ <i class=tj-silent>ٱ</i>لْإِ<i class=tj-ikhfa>نس</i>َ<i class=tj-madd>ـٰ</i>نَ مِنْ عَلَ<i class=tj-qalqalah>ق</i>ٍ","3":"ٱ<i class=tj-qalqalah>قْ</i>رَأْ وَرَبُّكَ <i class=tj-silent>ٱ</i>لْأَكْرَمُ","4":"ٱلَّذِى عَلَّمَ بِ<i class=tj-silent>ٱ</i>لْقَلَمِ","5":"عَلَّمَ <i class=tj-silent>ٱ</i>لْإِ<i class=tj-ikhfa>نس</i>َ<i class=tj-madd>ـٰ</i>نَ مَا لَمْ يَعْلَمْ","6":"كَلّ<i class=tj-madd>َآ</i> إِ<i class=tj-ghunnah>نّ</i>َ <i class=tj-silent>ٱ</i>لْإِ<i class=tj-ikhfa>نس</i>َ<i class=tj-madd>ـٰ</i>نَ لَيَ<i class=tj-qalqalah>طْ</i>غَىٰٓ","7":"أ<i class=tj-silent>َن ر</i>َّءَاهُ <i class=tj-silent>ٱ</i>سْتَغْنَىٰٓ","8":"إِ<i class=tj-ghunnah>نّ</i>َ إِلَىٰ رَبِّكَ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>رُّ<i class=tj-qalqalah>جْ</i>عَىٰٓ","9":"أَرَءَيْتَ <i class=tj-silent>ٱ</i>لَّذِى يَنْهَىٰ","10":"عَ<i class=tj-qalqalah>بْ</i>دًا إِذَا صَلَّىٰٓ","11":"أَرَءَيْتَ إِ<i class=tj-ikhfa>ن ك</i>َانَ عَلَى <i class=tj-silent>ٱ</i>لْهُدَىٰٓ","12":"أَوْ أَمَرَ بِ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>تَّ<i class=tj-qalqalah>قْ</i>وَىٰٓ","13":"أَرَءَيْتَ إِ<i class=tj-ikhfa>ن ك</i>َذَّبَ وَتَوَلَّىٰٓ","14":"أَلَمْ يَعْل<i class=tj-ikhfa>َم ب</i>ِأَ<i class=tj-ghunnah>نّ</i>َ <i class=tj-silent>ٱ</i>للَّهَ يَرَىٰ","15":"كَلَّا لَئ<i class=tj-silent>ِن ل</i>َّمْ يَ<i class=tj-ikhfa>نت</i>َهِ لَنَسْفَع<i class=tj-ikhfa>َۢا ب</i>ِ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i><i class=tj-ghunnah>نّ</i>َاصِيَةِ","16":"نَاصِيَ<i class=tj-ikhfa>ةٍ ك</i>َ<i class=tj-madd>ـٰ</i>ذِبَةٍ خَاطِئَةٍ","17":"فَلْيَ<i class=tj-qalqalah>دْ</i>عُ نَادِيَهُۥ","18":"سَنَ<i class=tj-qalqalah>دْ</i>عُ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>زَّبَانِيَةَ","19":"كَلَّا لَا تُطِعْهُ وَ<i class=tj-silent>ٱ</i>سْجُ<i class=tj-qalqalah>دْ</i> وَ<i class=tj-silent>ٱ</i><i class=tj-qalqalah>قْ</i>تَرِ<i class=tj-qalqalah>ب</i> ۩"}}