{"verses":{"1":"وَ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>سَّم<i class=tj-madd>َا</i>ٓءِ وَ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>طَّارِ<i class=tj-qalqalah>ق</i>ِ","2":"وَم<i class=tj-madd>َآ</i> أَ<i class=tj-qalqalah>دْ</i>رَ<i class=tj-madd>ٮٰ</i>كَ مَا <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>طَّارِ<i class=tj-qalqalah>ق</i>ُ","3":"ٱ<i class=tj-silent>ل</i><i class=tj-ghunnah>نّ</i>َ<i class=tj-qalqalah>جْ</i>مُ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>ثَّاقِ<i class=tj-qalqalah>ب</i>ُ","4":"إِ<i class=tj-ikhfa>ن ك</i>ُلُّ نَفْ<i class=tj-silent>سٍ ل</i>َّ<i class=tj-ghunnah>مّ</i>َا عَلَيْهَا حَافِظٌ","5":"فَلْيَ<i class=tj-ikhfa>نظ</i>ُرِ <i class=tj-silent>ٱ</i>لْإِ<i class=tj-ikhfa>نس</i>َ<i class=tj-madd>ـٰ</i>نُ مِ<i class=tj-ghunnah>مّ</i>َ خُلِ<i class=tj-qalqalah>ق</i>َ","6":"خُلِقَ م<i class=tj-ghunnah>ِن م</i>ّ<i class=tj-madd>َا</i>ٓ<i class=tj-ikhfa>ءٍ د</i>َافِ<i class=tj-qalqalah>ق</i>ٍ","7":"يَخْرُجُ م<i class=tj-ikhfa>ِنۢ ب</i>َيْنِ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>صُّلْبِ وَ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>تَّر<i class=tj-madd>َا</i>ٓئِ<i class=tj-qalqalah>ب</i>ِ","8":"إِ<i class=tj-ghunnah>نّ</i>َهُ<i class=tj-madd>ۥ</i> عَلَىٰ رَ<i class=tj-qalqalah>جْ</i>عِه<i class=tj-madd>ِۦ</i> لَقَادِرٌ","9":"يَوْمَ تُ<i class=tj-qalqalah>بْ</i>لَى <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>سَّر<i class=tj-madd>َا</i>ٓئِرُ","10":"فَمَا لَهُ<i class=tj-madd>ۥ</i> مِ<i class=tj-ikhfa>ن ق</i>ُوَّ<i class=tj-ghunnah>ةٍ و</i>َلَا نَاصِرٍ","11":"وَ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>سَّم<i class=tj-madd>َا</i>ٓءِ ذَاتِ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>رَّ<i class=tj-qalqalah>جْ</i>عِ","12":"وَ<i class=tj-silent>ٱ</i>لْأَرْضِ ذَاتِ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>صَّ<i class=tj-qalqalah>دْ</i>عِ","13":"إِ<i class=tj-ghunnah>نّ</i>َهُ<i class=tj-madd>ۥ</i> لَقَوْ<i class=tj-ikhfa>لٌ ف</i>َصْلٌ","14":"وَمَا هُوَ بِ<i class=tj-silent>ٱ</i>لْهَزْلِ","15":"إِ<i class=tj-ghunnah>نّ</i>َهُمْ يَكِيدُونَ كَيْدًا","16":"وَأَكِيدُ كَيْدًا","17":"فَمَهِّلِ <i class=tj-silent>ٱ</i>لْكَ<i class=tj-madd>ـٰ</i>فِرِينَ أَمْهِلْهُمْ رُوَيْدَۢا"}}