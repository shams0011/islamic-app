{"verses":{"1":"وَ<i class=tj-silent>ٱ</i>لْمُرْسَلَ<i class=tj-madd>ـٰ</i>تِ عُرْفًا","2":"فَ<i class=tj-silent>ٱ</i>لْعَ<i class=tj-madd>ـٰ</i>صِفَ<i class=tj-madd>ـٰ</i>تِ عَصْفًا","3":"وَ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i><i class=tj-ghunnah>نّ</i>َ<i class=tj-madd>ـٰ</i>شِر<i class=tj-madd>َٲ</i>تِ نَشْرًا","4":"فَ<i class=tj-silent>ٱ</i>لْفَ<i class=tj-madd>ـٰ</i>رِقَ<i class=tj-madd>ـٰ</i>تِ فَرْقًا","5":"فَ<i class=tj-silent>ٱ</i>لْمُلْقِيَ<i class=tj-madd>ـٰ</i>تِ ذِكْرًا","6":"عُذْرًا أَوْ نُذْرًا","7":"إِ<i class=tj-ghunnah>نّ</i>َمَا تُوعَدُونَ لَو<i class=tj-madd>َٲ</i>قِعٌ","8":"فَإِذَا <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i><i class=tj-ghunnah>نّ</i>ُجُومُ طُمِسَتْ","9":"وَإِذَا <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>سَّم<i class=tj-madd>َا</i>ٓءُ فُرِجَتْ","10":"وَإِذَا <i class=tj-silent>ٱ</i>لْجِبَالُ نُسِفَتْ","11":"وَإِذَا <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>رُّسُلُ أُقِّتَتْ","12":"لِأَىِّ يَوْمٍ أُجِّلَتْ","13":"لِيَوْمِ <i class=tj-silent>ٱ</i>لْفَصْلِ","14":"وَم<i class=tj-madd>َآ</i> أَ<i class=tj-qalqalah>دْ</i>رَ<i class=tj-madd>ٮٰ</i>كَ مَا يَوْمُ <i class=tj-silent>ٱ</i>لْفَصْلِ","15":"وَيْ<i class=tj-ghunnah>لٌ ي</i>َوْمَئِ<i class=tj-silent>ذٍ ل</i>ِّلْمُكَذِّب<i class=tj-madd>ِي</i>نَ","16":"أَلَمْ نُهْلِكِ <i class=tj-silent>ٱ</i>لْأَوَّل<i class=tj-madd>ِي</i>نَ","17":"ثُ<i class=tj-ghunnah>مّ</i>َ نُتْبِعُهُمُ <i class=tj-silent>ٱ</i>لْأَخِر<i class=tj-madd>ِي</i>نَ","18":"كَذ<i class=tj-madd>َٲ</i>لِكَ نَفْعَلُ بِ<i class=tj-silent>ٱ</i>لْمُ<i class=tj-qalqalah>جْ</i>رِم<i class=tj-madd>ِي</i>نَ","19":"وَيْ<i class=tj-ghunnah>لٌ ي</i>َوْمَئِ<i class=tj-silent>ذٍ ل</i>ِّلْمُكَذِّب<i class=tj-madd>ِي</i>نَ","20":"أَلَمْ نَخْلُ<i class=tj-silent>ق</i>كّ<i class=tj-ghunnah>ُم م</i>ّ<i class=tj-ghunnah>ِن م</i>ّ<i class=tj-madd>َا</i>ٓ<i class=tj-ghunnah>ءٍ م</i>َّه<i class=tj-madd>ِي</i>نٍ","21":"فَجَعَلْنَ<i class=tj-madd>ـٰ</i>هُ فِى قَرَا<i class=tj-ghunnah>رٍ م</i>َّك<i class=tj-madd>ِي</i>نٍ","22":"إِلَىٰ قَدَ<i class=tj-ghunnah>رٍ م</i>َّعْل<i class=tj-madd>ُو</i>مٍ","23":"فَقَدَرْنَا فَنِعْمَ <i class=tj-silent>ٱ</i>لْقَ<i class=tj-madd>ـٰ</i>دِر<i class=tj-madd>ُو</i>نَ","24":"وَيْ<i class=tj-ghunnah>لٌ ي</i>َوْمَئِ<i class=tj-silent>ذٍ ل</i>ِّلْمُكَذِّب<i class=tj-madd>ِي</i>نَ","25":"أَلَمْ نَ<i class=tj-qalqalah>جْ</i>عَلِ <i class=tj-silent>ٱ</i>لْأَرْضَ كِفَاتًا","26":"أَحْي<i class=tj-madd>َا</i>ٓ<i class=tj-ghunnah>ءً و</i>َأَمْو<i class=tj-madd>َٲ</i>تًا","27":"وَجَعَلْنَا فِيهَا رَو<i class=tj-madd>َٲ</i>سِىَ شَ<i class=tj-madd>ـٰ</i>مِخَ<i class=tj-madd>ـٰ</i><i class=tj-ghunnah>تٍ و</i>َأَسْقَيْنَ<i class=tj-madd>ـٰ</i>ك<i class=tj-ghunnah>ُم م</i>ّ<i class=tj-madd>َا</i>ٓ<i class=tj-ikhfa>ءً ف</i>ُرَاتًا","28":"وَيْ<i class=tj-ghunnah>لٌ ي</i>َوْمَئِ<i class=tj-silent>ذٍ ل</i>ِّلْمُكَذِّب<i class=tj-madd>ِي</i>نَ","29":"ٱ<i class=tj-ikhfa>نط</i>َلِق<i class=tj-madd>ُوٓ</i><i class=tj-silent>اْ</i> إِلَىٰ مَا كُ<i class=tj-ikhfa>نت</i><i class=tj-ikhfa>ُم ب</i>ِه<i class=tj-madd>ِۦ</i> تُكَذِّب<i class=tj-madd>ُو</i>نَ","30":"ٱ<i class=tj-ikhfa>نط</i>َلِق<i class=tj-madd>ُوٓ</i><i class=tj-silent>اْ</i> إِلَىٰ ظِ<i class=tj-ikhfa>لٍّ ذ</i>ِى ثَلَ<i class=tj-madd>ـٰ</i>ثِ شُعَ<i class=tj-qalqalah>ب</i>ٍ","31":"لَّا ظَلِي<i class=tj-ghunnah>لٍ و</i>َلَا يُغْنِى مِنَ <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>لَّهَ<i class=tj-qalqalah>ب</i>ِ","32":"إِ<i class=tj-ghunnah>نّ</i>َهَا تَرْمِى بِشَرَ<i class=tj-ikhfa>رٍ ك</i>َ<i class=tj-silent>ٱ</i>لْقَصْرِ","33":"كَأَ<i class=tj-ghunnah>نّ</i>َهُ<i class=tj-madd>ۥ</i> جِمَ<i class=tj-madd>ـٰ</i>لَ<i class=tj-ikhfa>تٌ ص</i>ُفْرٌ","34":"وَيْ<i class=tj-ghunnah>لٌ ي</i>َوْمَئِ<i class=tj-silent>ذٍ ل</i>ِّلْمُكَذِّب<i class=tj-madd>ِي</i>نَ","35":"هَ<i class=tj-madd>ـٰ</i>ذَا يَوْمُ لَا يَ<i class=tj-ikhfa>نط</i>ِق<i class=tj-madd>ُو</i>نَ","36":"وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِر<i class=tj-madd>ُو</i>نَ","37":"وَيْ<i class=tj-ghunnah>لٌ ي</i>َوْمَئِ<i class=tj-silent>ذٍ ل</i>ِّلْمُكَذِّب