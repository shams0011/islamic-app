{"verses":{"1":"إِذَا <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>سَّم<i class=tj-madd>َا</i>ٓءُ <i class=tj-silent>ٱ</i><i class=tj-ikhfa>نش</i>َقَّتْ","2":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","3":"وَإِذَا <i class=tj-silent>ٱ</i>لْأَرْضُ مُدَّتْ","4":"وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ","5":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","6":"يَ<i class=tj-madd>ـٰٓ</i>أَيُّهَا <i class=tj-silent>ٱ</i>لْإِ<i class=tj-ikhfa>نس</i>َ<i class=tj-madd>ـٰ</i>نُ إِ<i class=tj-ghunnah>نّ</i>َكَ كَادِحٌ إِلَىٰ رَبِّكَ كَ<i class=tj-qalqalah>دْ</i><i class=tj-ikhfa>حًا ف</i>َمُلَ<i class=tj-madd>ـٰ</i>ق<i class=tj-madd>ِي</i>هِ","7":"فَأَ<i class=tj-ghunnah>مّ</i>َا مَنْ أُوتِىَ كِتَ<i class=tj-madd>ـٰ</i>بَهُ<i class=tj-madd>ۥ</i> بِيَمِينِهِۦ","8":"فَسَوْفَ يُحَاسَبُ حِسَا<i class=tj-ghunnah>بًا ي</i>َسِيرًا","9":"وَيَ<i class=tj-ikhfa>نق</i>َلِبُ إِلَ<i class=tj-madd>ىٰٓ</i> أَهْلِه<i class=tj-madd>ِۦ</i> مَسْرُورًا","10":"وَأَ<i class=tj-ghunnah>مّ</i>َا مَنْ أُوتِىَ كِتَ<i class=tj-madd>ـٰ</i>بَهُ<i class=tj-madd>ۥ</i> وَر<i class=tj-madd>َا</i>ٓءَ ظَهْرِهِۦ","11":"فَسَوْفَ يَ<i class=tj-qalqalah>دْ</i>عُو<i class=tj-silent>اْ</i> ثُبُورًا","12":"وَيَصْلَىٰ سَعِيرًا","13":"إِ<i class=tj-ghunnah>نّ</i>َهُ<i class=tj-madd>ۥ</i> كَانَ ف<i class=tj-madd>ِىٓ</i> أَهْلِه<i class=tj-madd>ِۦ</i> مَسْرُورًا","14":"إِ<i class=tj-ghunnah>نّ</i>َهُ<i class=tj-madd>ۥ</i> ظَ<i class=tj-ghunnah>نّ</i>َ أ<i class=tj-silent>َن ل</i>ّ<i class=tj-ghunnah>َن ي</i>َح<i class=tj-madd>ُو</i>رَ","15":"بَلَ<i class=tj-madd>ىٰٓ</i> إِ<i class=tj-ghunnah>نّ</i>َ رَبَّهُ<i class=tj-madd>ۥ</i> كَانَ بِه<i class=tj-madd>ِۦ</i> بَصِيرًا","16":"فَل<i class=tj-madd>َآ</i> أُ<i class=tj-qalqalah>قْ</i>سِمُ بِ<i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>شَّفَ<i class=tj-qalqalah>ق</i>ِ","17":"وَ<i class=tj-silent>ٱ</i>لَّيْلِ وَمَا وَسَ<i class=tj-qalqalah>ق</i>َ","18":"وَ<i class=tj-silent>ٱ</i>لْقَمَرِ إِذَا <i class=tj-silent>ٱ</i>تَّسَ<i class=tj-qalqalah>ق</i>َ","19":"لَتَرْكَبُ<i class=tj-ghunnah>نّ</i>َ طَبَقًا عَ<i class=tj-ikhfa>ن ط</i>َبَ<i class=tj-qalqalah>ق</i>ٍ","20":"فَمَا لَهُمْ لَا يُؤْمِن<i class=tj-madd>ُو</i>نَ","21":"وَإِذَا قُرِئَ عَلَيْهِمُ <i class=tj-silent>ٱ</i>لْقُرْءَانُ لَا يَسْجُدُ<i class=tj-madd>و</i>نَ ۩","22":"بَلِ <i class=tj-silent>ٱ</i>لَّذِينَ كَفَرُو<i class=tj-silent>اْ</i> يُكَذِّب<i class=tj-madd>ُو</i>نَ","23":"وَ<i class=tj-silent>ٱ</i>للَّهُ أَعْلَمُ بِمَا يُوع<i class=tj-madd>ُو</i>نَ","24":"فَبَشِّرْه<i class=tj-ikhfa>ُم ب</i>ِعَذَابٍ أَل<i class=tj-madd>ِي</i>مٍ","25":"إِلَّا <i class=tj-silent>ٱ</i>لَّذِينَ ءَامَنُو<i class=tj-silent>اْ</i> وَعَمِلُو<i class=tj-silent>اْ</i> <i class=tj-silent>ٱ</i><i class=tj-silent>ل</i>صَّ<i class=tj-madd>ـٰ</i>لِحَ<i class=tj-madd>ـٰ</i>تِ لَهُمْ أَ<i class=tj-qalqalah>جْ</i>رٌ غَيْرُ مَمْن<i class=tj-madd>ُو</i>نِۭ"}}